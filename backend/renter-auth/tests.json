      "path": "/?action=register",
      "body": {
        "email": "test_renter_ci@example.com",
        "password": "test123456",
        "company_name": "ТестПрокатCI",
        "contact_name": "Тест Тестов",
        "phone": "+79000000001",
        "city": "Санкт-Петербург"
