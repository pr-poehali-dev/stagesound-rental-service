    {
      "name": "Вход с неверным паролем",
      "method": "POST",
      "path": "/?action=login",
      "body": {"email": "test_renter@example.com", "password": "wrong"},
      "expectedStatus": 401,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
