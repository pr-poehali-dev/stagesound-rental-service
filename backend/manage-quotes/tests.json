{
  "tests": [
    {
      "name": "OPTIONS preflight",
      "method": "OPTIONS",
      "path": "/",
      "expectedStatus": 200
    },
    {
      "name": "GET without password returns 401",
      "method": "GET",
      "path": "/",
      "expectedStatus": 401
    },
    {
      "name": "GET by unknown token returns 404",
      "method": "GET",
      "path": "/?token=nonexistent_token_xyz",
      "expectedStatus": 404
    }
  ]
}
